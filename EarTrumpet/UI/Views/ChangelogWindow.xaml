<Window x:Class="EarTrumpet.UI.Views.ChangelogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resx="clr-namespace:EarTrumpet.Properties"
        Title="{x:Static resx:Resources.ChangelogTitle}"
        Width="480" Height="250"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BetterTrumpet;component/UI/Controls/OnboardingComponents.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource OnboardingBg}"
            CornerRadius="8"
            BorderBrush="{StaticResource OnboardingBorder}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Margin="32,32,32,20" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Width="36" Height="36" VerticalAlignment="Top">
                    <Ellipse Fill="#223B9EFF"/>
                    <Path Data="M 10,18 L 15.5,23.5 L 26,13"
                          Stroke="{StaticResource OnboardingAccent}"
                          StrokeThickness="2.2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"/>
                </Grid>

                <StackPanel Grid.Column="1" Margin="12,1,0,0">
                    <TextBlock Text="{x:Static resx:Resources.ChangelogTitle}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource OnboardingText}"
                               Margin="0,0,0,8"/>

                    <TextBlock x:Name="VersionMessage"
                               FontSize="14"
                               Foreground="{StaticResource OnboardingTextMuted}"
                               TextWrapping="Wrap"
                               LineHeight="21"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1"
                        Margin="24,0,24,24"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button Content="{x:Static resx:Resources.ChangelogViewReleaseNotes}"
                        Style="{StaticResource OnboardingGhostButton}"
                        Margin="0,0,8,0"
                        Click="ViewReleaseNotes_Click"/>

                <Button Content="{x:Static resx:Resources.ChangelogContinue}"
                        Style="{StaticResource OnboardingPrimaryButton}"
                        MinWidth="88"
                        IsDefault="True"
                        Click="Continue_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
