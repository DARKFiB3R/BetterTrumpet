                 case User32.WM_LBUTTONUP:
-                    // Windows can deliver two separate notifications (NIN_SELECT and
-                    // WM_LBUTTONUP) for a single physical click, inconsistently - sometimes
-                    // both arrive, sometimes only one. Genuine duplicate messages for the
-                    // same click land within milliseconds of each other; separate clicks are
-                    // naturally seconds apart at minimum. A time-based debounce distinguishes
-                    // these reliably, unlike a stateful flag that can only "remember" whether
-                    // the previous message was a duplicate - which breaks whenever a click
-                    // happens to produce just one message, since nothing is ever left to
-                    // consume and reset that state before the next, unrelated click arrives.
-                    var now = DateTime.UtcNow;
-                    if ((now - _lastButtonUpProcessedAt) > TimeSpan.FromMilliseconds(100))
+                    // Observed double WM_CALLBACKMOUSEMSG/WM_LBUTTONUP pairs on Windows 11 22533
