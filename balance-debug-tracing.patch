+                    // For now, swallow the duplicate to improve flyout UX.
+                    System.Diagnostics.Trace.WriteLine($"[TrayClick] {DateTime.UtcNow:HH:mm:ss.fff} raw message={(short)msg.LParam} HasAlreadyProcessedButtonUp(before-read)={_hasAlreadyProcessedButtonUp}");
+                    if (!HasAlreadyProcessedButtonUp)
